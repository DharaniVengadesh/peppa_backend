NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=peppa
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Email (household invites)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=Peppa <noreply@peppa.app>

# App URLs
APP_URL=http://192.168.31.216:3000
MOBILE_DEEP_LINK=peppa://join

# CORS (add admin dashboard origin when built in Sprint 7)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://192.168.31.216:3000

# Super Admin (seeded on db:seed)
ADMIN_EMAIL=admin@peppa.app
ADMIN_PASSWORD=Admin123!
